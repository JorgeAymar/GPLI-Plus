# Production env file for docker-compose.prod.yml (Docker Swarm stack).
#
# Copy to .env.production and fill in real values before the first deploy:
#   cp .env.production.example .env.production
# .env.production is gitignored (matches the .env.* rule) — never commit it.
#
# This single file is loaded via `env_file:` by BOTH services in
# docker-compose.prod.yml. Postgres only reads the POSTGRES_* vars; web only
# reads the rest. The extra vars each container sees are unused, but keeping
# one file avoids two places to update credentials in sync.

# --- Postgres (consumed by the "postgres" service to init the DB) ---
POSTGRES_USER=itsm
POSTGRES_PASSWORD=replace-with-a-strong-password
POSTGRES_DB=itsm

# --- Web app ---
# Host MUST be "postgres" (the Swarm-internal service DNS name on the
# itsm_internal overlay network), not localhost — the app and DB run in
# separate containers reachable only via the overlay network's routing mesh.
# Keep user/password/db in sync with the POSTGRES_* vars above.
DATABASE_URL=postgres://itsm:replace-with-a-strong-password@postgres:5432/itsm

# Auth.js
AUTH_SECRET=replace-with-openssl-rand-base64-32
AUTH_URL=https://cliente.example.com

# Storage adapter. "local" is the only driver actually implemented today
# (packages/core/src/storage/storage-adapter.ts throws on any other value) —
# .env.example lists commented-out STORAGE_S3_* vars as a documented-but-not-
# built future option (see docs/architecture-plan.md), not a usable
# alternative yet. Don't set STORAGE_DRIVER=s3 here.
#
# STORAGE_LOCAL_PATH resolves relative to the container's WORKDIR (/app, see
# apps/web/Dockerfile) -> /app/.data/documents. docker-compose.prod.yml mounts
# a named volume (itsm_documents_data) at that exact path so uploaded
# ticket/asset attachments survive every deploy — if you change this value,
# update the volume's mount target to match.
STORAGE_DRIVER=local
STORAGE_LOCAL_PATH=./.data/documents

# Host port docker-compose.prod.yml publishes the app on (optional, defaults
# to 3000 if unset)
# WEB_PUBLISHED_PORT=3000
