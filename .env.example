# Postgres (docker-compose service in dev)
DATABASE_URL=postgres://itsm:itsm@localhost:5436/itsm

# Auth.js
AUTH_SECRET=replace-with-openssl-rand-base64-32
AUTH_URL=http://localhost:3210

# Generic OIDC provider (enterprise SSO) - optional. Set all 3 to enable the
# "SSO" sign-in option (Google Workspace, Azure AD/Entra ID, Okta, Auth0,
# any OIDC-compliant IdP). Leave unset to keep email/password-only login.
# OIDC_ISSUER=https://issuer.example.com
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=

# Storage adapter (local filesystem in dev)
STORAGE_DRIVER=local
STORAGE_LOCAL_PATH=./.data/documents

# Seed script (pnpm --filter @itsm/core seed) - creates this user on first run.
# Change both before seeding a real environment.
SEED_ADMIN_EMAIL=admin@itsm.local
SEED_ADMIN_PASSWORD=ChangeMe123!

# S3-compatible storage (prod)
# STORAGE_DRIVER=s3
# STORAGE_S3_ENDPOINT=
# STORAGE_S3_BUCKET=
# STORAGE_S3_ACCESS_KEY_ID=
# STORAGE_S3_SECRET_ACCESS_KEY=

# SMTP (outgoing email: notifications, password recovery, login 2FA codes).
# Without this, those emails just get logged to the console instead of sent.
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=

# AI Assistant (optional) - built into the app itself (chat + live-data tool
# calling against your own tickets/assets/computers/problems/changes via
# Ollama). Leave AI_URL unset to hide the assistant entirely (e.g. installs
# without one).
# AI_URL=http://localhost:11434
# AI_API_KEY=
# AI_MODEL=

# Login 2FA is always on. In dev/e2e, this pre-fills the real emailed code
# into the login form instead of only sending it, so Playwright (or you,
# manually) can complete the actual 2-step flow without reading an inbox.
# NEVER set this in a real deployment - it's a no-op there anyway (also
# gated by NODE_ENV !== "production" in code), but it shouldn't be set at all.
# E2E_TEST_MODE=true

# apps/worker cron overrides (optional - each defaults to the value shown, no
# restart-required config file, just re-deploy the worker with the var set)
# SLA_ESCALATION_CRON=*/5 * * * *
# RECURRING_TICKETS_CRON=*/15 * * * *
# NOTIFICATION_DISPATCH_CRON=* * * * *
# SAVED_SEARCH_ALERTS_CRON=*/15 * * * *
# WEBHOOK_DISPATCH_CRON=* * * * *
# RSS_FEED_REFRESH_CRON=*/15 * * * *
